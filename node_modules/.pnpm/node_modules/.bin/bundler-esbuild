#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/data/museum/admin/node_modules/.pnpm/@umijs+bundler-esbuild@4.6.33/node_modules/@umijs/bundler-esbuild/node_modules:/data/museum/admin/node_modules/.pnpm/@umijs+bundler-esbuild@4.6.33/node_modules:/data/museum/admin/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/data/museum/admin/node_modules/.pnpm/@umijs+bundler-esbuild@4.6.33/node_modules/@umijs/bundler-esbuild/node_modules:/data/museum/admin/node_modules/.pnpm/@umijs+bundler-esbuild@4.6.33/node_modules:/data/museum/admin/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@umijs/bundler-esbuild/bin/bundler-esbuild.js" "$@"
else
  exec node  "$basedir/../@umijs/bundler-esbuild/bin/bundler-esbuild.js" "$@"
fi
